---
import Button from './Button.astro';
const GH = 'https://github.com/stuffbucket/bladerunner';
const DOCS = 'https://github.com/stuffbucket/bladerunner#readme';
---
<nav id="nav" aria-label="Primary">
  <div class="wrap nav-inner">
    <a class="wordmark" href="#top" aria-label="bladerunner home">
      <span class="wm-name">bladerunner</span>
      <span class="wm-glyph" aria-hidden="true">&gt;_</span>
    </a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="nav-sheet" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav-links" id="nav-sheet">
      <a href="#features">Features</a>
      <a href="#quickstart">Quickstart</a>
      <a href="#why">Why</a>
      <a href={DOCS} target="_blank" rel="noopener noreferrer">Docs</a>
      <div class="nav-actions">
        <Button variant="outline" size="sm" href={GH} external>GitHub ↗</Button>
        <Button variant="primary" size="sm" href="#install">Install</Button>
      </div>
    </div>
  </div>
</nav>

<style>
  #nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(251, 252, 252, 0.82);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    transition: background var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  #nav.is-scrolled { background: var(--bg); }

  .nav-inner {
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-6);
  }
  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    text-decoration: none;
  }
  .wm-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .wm-glyph {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--s-8);
  }
  .nav-links > a {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--t-nav);
    color: var(--muted);
    text-decoration: none;
    position: relative;
    padding: 4px 0;
    transition: color var(--dur) var(--ease);
  }
  .nav-links > a::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    width: 100%; height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur) var(--ease);
  }
  .nav-links > a:hover { color: var(--ink); }
  .nav-links > a:hover::after { transform: scaleX(1); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-left: var(--s-4);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px; height: 44px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    width: 20px; height: 2px;
    background: var(--ink);
    margin-inline: auto;
    transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 860px) {
    .nav-toggle { display: flex; }
    .nav-links {
      position: absolute;
      top: 64px; left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: var(--s-4);
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: var(--s-6) var(--gutter) var(--s-8);
      transform: translateY(-12px);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
    }
    .nav-links.is-open {
      transform: none;
      opacity: 1;
      pointer-events: auto;
    }
    .nav-links > a { font-size: 1.125rem; padding: 8px 0; }
    .nav-links > a::after { display: none; }
    .nav-actions {
      flex-direction: column;
      align-items: stretch;
      margin-left: 0;
      gap: var(--s-3);
    }
    .nav-actions :global(.btn) { width: 100%; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => {
    if (!nav) return;
    nav.classList.toggle('is-scrolled', window.scrollY > 8);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const sheet = document.getElementById('nav-sheet');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    sheet?.classList.toggle('is-open', !open);
  });
  sheet?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      sheet.classList.remove('is-open');
    })
  );
</script>
