---
const typical = ['your Mac', 'QEMU', 'Lima', 'Colima', 'Incus'];
const blade = ['your Mac', 'Virtualization.framework', 'Incus'];
---
<div class="stack" aria-hidden="false">
  <div class="stack-col">
    <p class="stack-head">Typical <code>colima --runtime incus</code></p>
    <ul class="stack-list muted-stack">
      {typical.map((cell) => (<li class="stack-cell">{cell}</li>))}
    </ul>
  </div>

  <div class="stack-arrow" aria-hidden="true">→</div>

  <div class="stack-col">
    <p class="stack-head accent-head">bladerunner</p>
    <ul class="stack-list accent-stack">
      {blade.map((cell) => (<li class="stack-cell">{cell}</li>))}
    </ul>
  </div>
</div>

<style>
  .stack {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--s-8);
    align-items: center;
    margin-top: var(--s-16);
  }
  .stack-col { display: flex; flex-direction: column; }
  .stack-head {
    font-family: var(--font-mono);
    font-size: var(--t-mono);
    color: var(--muted);
    margin-bottom: var(--s-4);
  }
  .stack-head code { font-family: inherit; color: var(--body); }
  .accent-head { color: var(--accent-ink); }

  .stack-list { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--s-2); }
  .stack-cell {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    text-align: center;
    padding: 14px 12px;
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    background: var(--surface);
    color: var(--body);
  }
  .muted-stack .stack-cell { color: var(--muted); }
  .accent-stack .stack-cell {
    border-color: var(--accent);
    background: var(--accent-wash);
    color: var(--accent-ink);
    font-weight: 500;
  }

  .stack-arrow {
    font-size: 1.75rem;
    color: var(--faint);
    align-self: center;
  }

  @media (max-width: 767px) {
    .stack { grid-template-columns: 1fr; gap: var(--s-6); }
    .stack-arrow { transform: rotate(90deg); justify-self: center; }
  }
</style>
