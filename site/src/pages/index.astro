---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SsoMarquee from '../components/SsoMarquee.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Quickstart from '../components/Quickstart.astro';
import Why from '../components/Why.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';

const REPO = 'stuffbucket/bladerunner';

// Version the page advertises. A pin (VITE_SITE_PIN_VERSION, surfaced from the
// SITE_PIN_VERSION repo variable by pages.yml) wins; otherwise track GitHub's
// /releases/latest at build time. Pin/unpin via site-pin.yml. The version chip
// is non-critical, so any lookup failure just drops it (build never fails).
const PINNED_TAG = (import.meta.env.VITE_SITE_PIN_VERSION ?? '').trim();

async function fetchLatestTag(): Promise<string | null> {
  try {
    const token = (process.env.GITHUB_TOKEN ?? '').trim();
    const headers: Record<string, string> = {
      Accept: 'application/vnd.github+json',
      'User-Agent': 'bladerunner-site-build',
      'X-GitHub-Api-Version': '2022-11-28',
    };
    if (token) headers.Authorization = `Bearer ${token}`;
    const res = await fetch(`https://api.github.com/repos/${REPO}/releases/latest`, { headers });
    if (!res.ok) return null;
    const body = (await res.json()) as { tag_name?: string };
    return typeof body.tag_name === 'string' && body.tag_name.length > 0 ? body.tag_name : null;
  } catch {
    return null;
  }
}

const tag = PINNED_TAG || (await fetchLatestTag());
const version = tag ? tag.replace(/^v/, '') : null;
const releaseUrl = tag
  ? `https://github.com/${REPO}/releases/tag/${tag}`
  : `https://github.com/${REPO}/releases`;
---
<Base>
  <Nav />
  <main>
    <Hero version={version} releaseUrl={releaseUrl} />
    <SsoMarquee />
    <FeatureGrid />
    <Quickstart />
    <Why />
    <FinalCta />
  </main>
  <Footer />

  <!-- aria-live region for copy success -->
  <div id="copy-live" class="sr-only" aria-live="polite"></div>
</Base>

<script>
  // ============================================================
  // Global: click-to-copy (buttons w/ data-copy) + scroll reveal
  // ============================================================
  const live = document.getElementById('copy-live');

  async function copyText(text: string): Promise<boolean> {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      // fallback
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      let ok = false;
      try { ok = document.execCommand('copy'); } catch { ok = false; }
      document.body.removeChild(ta);
      return ok;
    }
  }

  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    const text = btn.getAttribute('data-copy') || '';
    const labelEl = btn.querySelector<HTMLElement>('.copy-label, .copy-text');
    const glyphEl = btn.querySelector<HTMLElement>('.copy-glyph');
    const original = labelEl?.textContent ?? '';
    let timer: number | undefined;

    btn.addEventListener('click', async () => {
      const ok = await copyText(text);
      if (!ok) return;
      btn.classList.add('is-copied');
      if (labelEl) labelEl.textContent = 'copied ✓';
      if (glyphEl) glyphEl.style.display = 'none';
      if (live) live.textContent = `Copied: ${text}`;
      window.clearTimeout(timer);
      timer = window.setTimeout(() => {
        btn.classList.remove('is-copied');
        if (labelEl) labelEl.textContent = original;
        if (glyphEl) glyphEl.style.display = '';
        if (live) live.textContent = '';
      }, 1400);
    });
  });

  // ---- scroll reveal ----
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const reveals = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
  if (reduce) {
    reveals.forEach((el) => el.classList.add('is-in'));
  } else {
    const io = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((e, i) => {
          if (e.isIntersecting) {
            const el = e.target as HTMLElement;
            window.setTimeout(() => el.classList.add('is-in'), (i % 3) * 60);
            obs.unobserve(el);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
    );
    reveals.forEach((el) => io.observe(el));
  }
</script>
